# hw definition file for processing by chibios_pins.py
# for DevEBoxH743VIT6 bootloader

MCU STM32H7xx STM32H743xx

APJ_BOARD_ID AP_HW_DEVEBOXH7

OSCILLATOR_HZ 25000000

FLASH_SIZE_KB 2048

# Bootloader occupies the first 128 KB sector
FLASH_RESERVE_START_KB 0
FLASH_BOOTLOADER_LOAD_KB 128

# USB only in bootloader
SERIAL_ORDER OTG1

PA11 OTG_FS_DM OTG1
PA12 OTG_FS_DP OTG1

PA13 JTMS-SWDIO SWD
PA14 JTCK-SWCLK SWD

# Bootloader LED (same pin as application)
PA1 LED_BOOTLOADER OUTPUT LOW
define HAL_LED_ON 0

# Hold all SPI CS lines high during bootloader so devices stay idle
PC4 MPU6500_CS CS

define HAL_USE_EMPTY_STORAGE 1
define HAL_STORAGE_SIZE 16384
